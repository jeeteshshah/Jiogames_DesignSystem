{
  "_meta": {
    "version": "1.0.0",
    "description": "JioGames DLS — design tokens source of truth. Run build.py to regenerate tokens.css.",
    "fontWeights": [300, 500, 700, 900],
    "fontFamily": "JioType"
  },

  "color": {
    "_comment": "Brand green",
    "jio":        "#00A859",
    "jio-2":      "#22C16C",
    "jio-3":      "#88E5AB",
    "jio-bright": "#00E870",
    "jio-glow":   "rgba(0,200,100,.35)",
    "jio-soft":   "rgba(0,168,89,.12)",

    "_comment2": "Pass / premium",
    "ultimate":              "#00cc65",
    "ultimate-glow":         "rgba(0,200,100,.35)",
    "popular-gold":          "#F7AB20",
    "popular-gold-2":        "#FFCF5C",
    "pass-mobile-bg":        "#061A10",
    "pass-ultimate-bg-start":"#051F12",
    "pass-ultimate-bg-end":  "#071A1A",

    "_comment3": "Functional accents",
    "gold":       "#FFC23D",
    "gold-laurel":"#c9a84c",
    "amber":      "#F59E0B",
    "amber-soft": "rgba(245,158,11,.15)",
    "red":        "#FF4757",
    "pink":       "#FF3D7F",
    "negative":   "#FF4757",
    "positive":   "#00A859",
    "info":       "#3B8BEB",

    "_comment4": "Backgrounds",
    "bg":        "#06080F",
    "card-bg":   "#111115",
    "sheet-bg":  "#0e1118",
    "sheet-top": "#131720",

    "_comment5": "Surface ladder (opaque)",
    "surface-1": "#0E1119",
    "surface-2": "#161A24",
    "surface-3": "#1F2432",
    "surface-4": "#2A3142",

    "_comment6": "Glass surfaces",
    "glass-1": "rgba(255,255,255,.055)",
    "glass-2": "rgba(255,255,255,.03)",
    "chip-bg": "#0c0f14",

    "_comment7": "Text",
    "text":     "#F4F2EE",
    "text2":    "#A8ADBA",
    "text3":    "#6B7280",
    "_comment7b": "text3 (#6B7280) is muted/disabled text only — contrast ~2.9:1 on --bg, fails WCAG AA for readable text. Use --text-placeholder (#8B92A5, 6.4:1) for placeholder/helper text.",
    "text4":    "#454A57",
    "text-inv": "#000000",

    "_comment8": "Borders",
    "border":          "rgba(255,255,255,.1)",
    "border-strong":   "rgba(255,255,255,.14)",
    "border-subtle":   "rgba(255,255,255,.08)",
    "border-ultimate": "rgba(0,204,101,.3)",
    "divider":         "rgba(255,255,255,.07)",
    "_comment8b": "divider = list row separators (slightly lighter for readability in dense lists); hairline = thin card/container borders. Different values are intentional.",
    "hairline":        "rgba(255,255,255,.08)",
    "hairline-2":      "rgba(255,255,255,.16)",

    "_comment9": "Overlay",
    "overlay-scrim": "rgba(0,0,0,.55)"
  },

  "spacing": {
    "0":    "0px",
    "0-25": "2px",
    "0-5":  "4px",
    "1":    "8px",
    "1-5":  "12px",
    "2":    "16px",
    "3":    "24px",
    "4":    "32px",
    "5":    "40px",
    "6":    "48px",
    "8":    "64px",
    "10":   "80px",
    "12":   "96px"
  },

  "semanticSpacing": {
    "gutter":            "16px",
    "section-gap":       "32px",
    "card-gap":          "12px",
    "component-padding": "16px",
    "card-padding":      "16px",
    "sheet-padding":     "24px",
    "hero-gap":          "32px",

    "_web": {
      "gutter":            "40px",
      "section-gap":       "48px",
      "card-gap":          "24px",
      "component-padding": "24px",
      "card-padding":      "24px",
      "sheet-padding":     "32px",
      "hero-gap":          "64px"
    },
    "_tv": {
      "gutter":            "80px",
      "section-gap":       "64px",
      "card-gap":          "24px",
      "component-padding": "32px",
      "card-padding":      "32px",
      "hero-gap":          "96px"
    }
  },

  "radius": {
    "r1":   "8px",
    "r2":   "10px",
    "r3":   "12px",
    "r4":   "14px",
    "r5":   "16px",
    "r6":   "18px",
    "r7":   "20px",
    "r8":   "22px",
    "r9":   "28px",
    "pill": "100px"
  },

  "layout": {
    "frame-mobile-w":  "393px",
    "frame-mobile-h":  "852px",
    "container-web":   "1280px",
    "tv-safe":         "80px",
    "web-grid-gap":    "24px",
    "hero-text-max":   "640px",
    "grid-cols-mobile":"4",
    "grid-cols-web":   "12",
    "grid-cols-tv":    "12",
    "_comment_grid": "Column gap tokens per platform",
    "col-gap-mobile":  "12px",
    "col-gap-web":     "24px",
    "col-gap-tv":      "32px",
    "_comment_bp": "Breakpoints (min-width)",
    "bp-web":          "768px",
    "bp-tv":           "1280px",
    "bp-tv-height":    "720px"
  },

  "zIndex": {
    "_comment": "Stacking order — never use raw integers outside this scale",
    "base":      "0",
    "raised":    "10",
    "dropdown":  "100",
    "sticky":    "200",
    "appbar":    "300",
    "drawer":    "400",
    "modal":     "500",
    "toast":     "600",
    "tooltip":   "700",
    "tvFocus":   "800"
  },

  "size": {
    "_comment": "Control heights (mobile base). --ctrl-h is the primitive; use --input-h (semantic alias) in component code.",
    "_comment_ctrl-h": "DEPRECATION: --ctrl-h will be removed in v2.0. Canonical semantic name is --input-h. Components should reference --input-h.",
    "ctrl-h":      "54px",
    "ctrl-h-sm":   "36px",
    "ctrl-h-ghost":"44px",
    "touch-min":   "44px",
    "otp-box-w":   "50px",
    "otp-box-h":   "64px",
    "card-wide-w": "272px",
    "card-sq":     "96px",
    "genre-tile-h":"156px",
    "tab-bar-h":   "64px",
    "app-bar-h":   "64px",
    "status-bar-h":"44px",

    "icon-size-xs":  "14px",
    "icon-size-sm":  "16px",
    "icon-size-md":  "20px",
    "icon-size-base":"24px",
    "icon-size-lg":  "32px",
    "icon-size-xl":  "40px",

    "icon-color-default": "rgba(255,255,255,.45)",
    "icon-color-active":  "#00A859",
    "icon-color-muted":   "#6B7280",
    "icon-wrapper-sm":    "44px",
    "icon-wrapper-md":    "48px",

    "_tv": {
      "ctrl-h":      "72px",
      "touch-min":   "60px",
      "card-wide-w": "400px"
    }
  },

  "font": {
    "family": "'JioType', -apple-system, BlinkMacSystemFont, sans-serif"
  },

  "motion": {
    "easing": {
      "spring":        "cubic-bezier(.22,1,.36,1)",
      "spring-bounce": "cubic-bezier(.34,1.56,.64,1)",
      "ease-screen":   "cubic-bezier(.42,0,.18,1)",
      "ease-out":      "cubic-bezier(0,0,.2,1)",
      "ease-error":    "cubic-bezier(.36,.07,.19,.97)",
      "_comment_emphasized": "Emphasized decelerate — sheets, drawers, deliberate slides. Stronger initial speed than --spring.",
      "ease-emphasized": "cubic-bezier(.32,.72,0,1)"
    },
    "duration": {
      "instant":      "90ms",
      "fast":         "120ms",
      "default":      "200ms",
      "pop":          "280ms",
      "_comment_slow": "Deliberate slides/reveals — sheet/drawer/carousel slide, chart reveal. Between pop and error.",
      "slow":         "320ms",
      "error":        "380ms",
      "sheet":        "400ms",
      "enter":        "420ms",
      "_comment_enter": "enter = element/component entrance (hero card, modal open). screen = page/screen transition. Same value now but kept separate — they describe different UX moments and may diverge.",
      "screen":       "420ms",
      "tv-enter":     "560ms",
      "shimmer":      "1600ms",
      "icon-spin":    "1000ms",
      "reduced-fade":    "100ms",
      "reduced-instant": "1ms"
    },
    "stagger": {
      "start": "50ms",
      "step":  "60ms"
    },
    "_comment_distance": "Movement distance tokens — translate offsets for enter/exit. Use var(--move-*) in keyframes instead of raw px.",
    "distance": {
      "sm": "8px",
      "md": "20px",
      "tv": "32px"
    },
    "_comment_scale": "Interactive scale tokens — governed feedback. press = touch pull, select = comes forward, tv-focus = D-pad focus. Never exceed these in component CSS (see motion.md §8).",
    "scale": {
      "press-sm":  "0.96",
      "press":     "0.98",
      "select":    "1.03",
      "tv-focus":  "1.05"
    }
  },

  "semantic": {
    "focus": {
      "ring-color":  "var(--jio)",
      "ring-width":  "2px",
      "ring-offset": "3px",
      "ring-tv":     "3px solid var(--jio)",
      "glow-tv":     "0 0 0 3px var(--jio), 0 0 24px var(--jio-glow)"
    },
    "button": {
      "primary-bg":         "var(--jio)",
      "primary-text":       "var(--text-inv)",
      "primary-hover-bg":   "#00be65",
      "secondary-bg":       "transparent",
      "secondary-border":   "var(--border-strong)",
      "secondary-text":     "var(--text)",
      "tertiary-bg":        "var(--glass-1)",
      "tertiary-border":    "var(--border-subtle)",
      "ghost-bg":           "transparent",
      "ghost-border":       "var(--border)",
      "ghost-text":         "var(--text2)",
      "destructive-bg":     "rgba(255,71,87,.12)",
      "destructive-border": "rgba(255,71,87,.3)",
      "destructive-text":   "var(--negative)",
      "ultimate-bg":        "linear-gradient(135deg, var(--ultimate), var(--jio-bright))",
      "ultimate-text":      "var(--text-inv)",
      "disabled-opacity":   "0.32",
      "loading-opacity":    "0.6"
    },
    "card": {
      "radius-landscape": "var(--r5)",
      "radius-portrait":  "var(--r5)",
      "radius-square":    "var(--r3)",
      "overlay":          "linear-gradient(0deg, rgba(6,8,15,.85) 0%, transparent 55%)",
      "overlay-heavy":    "linear-gradient(0deg, rgba(6,8,15,.95) 0%, transparent 70%)",
      "shimmer-bg":       "var(--surface-2)",
      "shimmer-shine":    "rgba(255,255,255,.04)",
      "active-scale":     "0.97"
    },
    "input": {
      "bg":           "var(--surface-1)",
      "border":       "var(--border)",
      "border-focus": "var(--jio)",
      "border-error": "var(--negative)",
      "text":         "var(--text)",
      "placeholder":  "var(--text-placeholder)",
      "h":            "var(--ctrl-h)",
      "radius":       "var(--r4)"
    },
    "surface": {
      "page":    "var(--bg)",
      "card":    "var(--card-bg)",
      "sheet":   "var(--sheet-bg)",
      "overlay": "var(--surface-3)",
      "chip":    "var(--chip-bg)"
    },
    "text": {
      "primary":     "var(--text)",
      "secondary":   "var(--text2)",
      "muted":       "var(--text3)",
      "disabled":    "var(--text4)",
      "placeholder": "#8B92A5",
      "positive":    "var(--positive)",
      "negative":    "var(--negative)",
      "brand":       "var(--jio)"
    },
    "shadow": {
      "1":       "0 1px 4px rgba(0,0,0,.3)",
      "2":       "0 4px 12px rgba(0,0,0,.4)",
      "3":       "0 8px 24px rgba(0,0,0,.5)",
      "4":       "0 16px 48px rgba(0,0,0,.6)",
      "glow":    "0 8px 32px var(--jio-glow)",
      "tv-card": "0 16px 64px rgba(0,0,0,.8)"
    },
    "state": {
      "hover-bg":         "rgba(255,255,255,.06)",
      "hover-border":     "rgba(255,255,255,.18)",
      "hover-text":       "var(--text)",
      "pressed-bg":       "rgba(255,255,255,.03)",
      "pressed-scale":    "0.97",
      "pressed-opacity":  "0.85",
      "selected-bg":      "var(--jio-soft)",
      "selected-border":  "rgba(0,168,89,.4)",
      "selected-text":    "var(--jio)",
      "disabled-bg":      "rgba(255,255,255,.04)",
      "disabled-border":  "rgba(255,255,255,.06)",
      "disabled-text":    "var(--text4)",
      "disabled-opacity": "0.32",
      "loading-bg":       "var(--surface-2)"
    },
    "spinner": {
      "size-sm":  "16px",
      "size-md":  "20px",
      "size-lg":  "24px",
      "size-tv":  "40px",
      "stroke":   "2px"
    },
    "success": {
      "color":  "#00A859",
      "soft":   "rgba(0,168,89,.12)",
      "border": "rgba(0,168,89,.3)",
      "text":   "#00A859"
    },
    "warning": {
      "color":  "#F59E0B",
      "soft":   "rgba(245,158,11,.12)",
      "border": "rgba(245,158,11,.3)",
      "text":   "#F59E0B"
    },
    "error": {
      "color":  "#FF4757",
      "soft":   "rgba(255,71,87,.12)",
      "border": "rgba(255,71,87,.3)",
      "text":   "#FF4757"
    },
    "destructive": {
      "color": "#FF4757",
      "soft":  "rgba(255,71,87,.12)"
    },
    "premium": {
      "color":     "#00cc65",
      "soft":      "rgba(0,204,101,.1)",
      "gradient":  "linear-gradient(135deg, #00cc65, #00E870)",
      "border":    "rgba(0,204,101,.35)",
      "glow":      "0 0 24px rgba(0,200,100,.4)"
    },
    "locked": {
      "bg":                 "rgba(6,8,15,.7)",
      "overlay":            "rgba(6,8,15,.75)",
      "unavailable-opacity":"0.4",
      "unavailable-overlay":"rgba(6,8,15,.5)"
    },
    "skeleton": {
      "bg":        "var(--surface-2)",
      "highlight": "var(--surface-3)",
      "radius":    "var(--r2)"
    },
    "overlay": {
      "card":    "linear-gradient(0deg, rgba(6,8,15,.85) 0%, transparent 55%)",
      "image":   "linear-gradient(180deg, transparent 40%, rgba(6,8,15,.9) 100%)",
      "locked":  "rgba(6,8,15,.72)",
      "premium": "rgba(0,10,5,.6)"
    },
    "status": {
      "_comment": "Status tokens — decoupled from brand. --positive visually matches --jio today but must not alias it. Brand can change; status semantics must not.",
      "positive":        "var(--positive)",
      "positive-soft":   "rgba(0,168,89,.12)",
      "positive-border": "rgba(0,168,89,.3)",
      "negative":        "var(--negative)",
      "negative-soft":   "rgba(255,71,87,.12)",
      "negative-border": "rgba(255,71,87,.3)",
      "warning":         "var(--amber)",
      "warning-soft":    "rgba(245,158,11,.12)",
      "warning-border":  "rgba(245,158,11,.3)",
      "info":            "var(--info)",
      "info-soft":       "rgba(59,139,235,.12)",
      "info-border":     "rgba(59,139,235,.3)"
    },
    "action": {
      "_comment": "Action tokens — semantic layer over brand. Use --action-primary instead of --jio in component code. When brand pivots, only this mapping changes.",
      "primary":       "var(--jio)",
      "primary-hover": "#00be65"
    },
    "focus-state": {
      "shadow":         "0 0 0 var(--focus-ring-width) var(--focus-ring-color)",
      "tv-ring-color":  "var(--jio)",
      "tv-shadow":      "0 0 0 3px var(--jio), 0 0 24px var(--jio-glow), 0 0 48px rgba(0,200,100,.2)",
      "tv-scale":       "1.05"
    }
  },

  "platformSize": {
    "button": {
      "height": {
        "mobile": { "xs":"28px","s":"36px","m":"44px","l":"54px","xl":"64px" },
        "web":    { "xs":"30px","s":"38px","m":"44px","l":"54px","xl":"64px" },
        "tv":     { "xs":"48px","s":"56px","m":"64px","l":"72px","xl":"80px" }
      },
      "padding": {
        "mobile": { "xs":"10px","s":"16px","m":"20px","l":"24px","xl":"32px" },
        "web":    { "xs":"12px","s":"18px","m":"22px","l":"28px","xl":"36px" },
        "tv":     { "xs":"20px","s":"28px","m":"36px","l":"44px","xl":"56px" }
      },
      "fontSize": {
        "mobile": { "xs":"11px","s":"13px","m":"14px","l":"15px","xl":"17px" },
        "web":    { "xs":"12px","s":"13px","m":"14px","l":"16px","xl":"18px" },
        "tv":     { "xs":"14px","s":"16px","m":"18px","l":"20px","xl":"22px" }
      }
    },
    "icon": {
      "size": {
        "mobile": { "xs":"12px","s":"16px","m":"20px","l":"24px","xl":"32px" },
        "web":    { "xs":"12px","s":"16px","m":"20px","l":"24px","xl":"32px" },
        "tv":     { "xs":"20px","s":"24px","m":"32px","l":"40px","xl":"48px" }
      },
      "wrap": {
        "mobile": { "xs":"32px","s":"36px","m":"44px","l":"48px","xl":"56px" },
        "web":    { "xs":"32px","s":"36px","m":"40px","l":"48px","xl":"56px" },
        "tv":     { "xs":"52px","s":"60px","m":"68px","l":"76px","xl":"84px" }
      }
    },
    "input": {
      "height": {
        "mobile": { "s":"36px","m":"44px","l":"54px" },
        "web":    { "s":"38px","m":"44px","l":"52px" },
        "tv":     { "s":"56px","m":"64px","l":"72px" }
      }
    },
    "chip": {
      "height": {
        "mobile": { "xs":"24px","s":"30px","m":"36px","l":"44px" },
        "web":    { "xs":"24px","s":"30px","m":"36px","l":"42px" },
        "tv":     { "xs":"44px","s":"52px","m":"60px","l":"68px" }
      }
    }
  }
}

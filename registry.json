{
  "$schema": "./registry.schema.json",
  "version": "1.0.0",
  "updated": "2026-06-27",
  "owner": "Jeetesh Shah",

  "statusDefinitions": {
    "stable": "Contracted. Complete anatomy, all states, all platforms. Safe to ship.",
    "beta":   "Usable and documented but not fully contracted. API may change.",
    "draft":  "Scaffolded page only. Do not use in production."
  },

  "namingConvention": {
    "folders":   "kebab-case. Plural for collections (buttons, cards, chips). Singular for unique/layout (tab-bar, app-bar, search, bottom-sheet).",
    "cssClass":  ".ds-[component]-[element]--[modifier]. Always ds- prefix. Never .component- prefix.",
    "tokenName": "--[category]-[modifier]. Primitive first, semantic aliases second.",
    "iconId":    "ic_[name]_[variant] in snake_case. Always ic_ prefix.",
    "jsEvent":   "camelCase. ds:[component]:[event] for custom events."
  },

  "categories": {
    "foundation": "Design decisions — colour, type, space, radius, motion, elevation",
    "core":       "Contracted systems — used everywhere, own the hardest constraints",
    "component":  "UI building blocks — composed from core, platform-specific variants",
    "feedback":   "State communication — loading, empty, error, progress",
    "form":       "Data entry — inputs, controls, validation",
    "overlay":    "Layered UI — floats above page content",
    "navigation": "Structural navigation — tabs, accordions, menus",
    "data":       "Data display — tables, charts, calendars",
    "layout":     "Spatial primitives — separators, aspect ratio, scroll areas"
  },

